{
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "devCommand": null,
  "framework": null,
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "rewrites": [
    { "source": "/contacts", "destination": "/contacts.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/download", "destination": "/download.html" },
    { "source": "/review", "destination": "/review.html" },
    { "source": "/restaurants", "destination": "/restaurants.html" },
    { "source": "/r/:slug", "destination": "/api/r/:slug" },
    { "source": "/u/:username", "destination": "/api/u/:username" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
