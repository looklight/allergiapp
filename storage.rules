rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Immagini recensioni
    match /reviews/{restaurantId}/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Immagini piatti (contributi)
    match /contributions/{restaurantId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Foto menu
    match /menus/{restaurantId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
