# Single source of truth: EAS Environment Variables (cloud).
# Sincronizzazione locale: `npm run env:sync`
# (alias di `eas env:pull --environment development` → genera .env)
#
# Per aggiungere una nuova variabile:
#   eas env:create --name FOO --value bar --environment preview --environment production
#
# EXPO_PUBLIC_*  → bundlate nel JS, accessibili runtime via process.env
# Senza prefisso → usate da app.config.ts a build/update time

# Supabase (Plaintext — anon key è pubblica per design)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Places / Maps (Sensitive — protette via bundle ID restrictions in Cloud Console)
GOOGLE_PLACES_API_KEY_IOS=your_ios_restricted_key
GOOGLE_PLACES_API_KEY_ANDROID=your_android_restricted_key
GOOGLE_MAPS_API_KEY_ANDROID=your_android_maps_key

# Solo per scripts/import/import-restaurants.js — locale, NON in EAS
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
GOOGLE_PLACES_API_KEY=your_unrestricted_key_for_local_imports
