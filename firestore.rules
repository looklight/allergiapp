rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: controlla se l'utente ha il custom claim admin
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Traduzioni pre-generate: lettura pubblica, scrittura solo admin
    match /translations/{langCode} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Utenti: qualsiasi utente autenticato può leggere, solo il proprietario può scrivere
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Preferiti: solo il proprietario
      match /favorites/{restaurantId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Collection group query su contributions (per profilo utente)
    match /{path=**}/contributions/{contributionId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.status == 'active');
    }

    // Ristoranti: lettura pubblica (status active), scrittura solo autenticati
    // Admin: lettura completa (qualsiasi status) e modifica campo status
    match /restaurants/{restaurantId} {
      allow read: if isAdmin() || resource == null || resource.data.status == 'active';
      allow create: if request.auth != null
        && request.resource.data.addedBy == request.auth.uid;
      allow update: if isAdmin()
        || (request.auth != null
        && (request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['favoriteCount', 'reviewCount', 'dishCount', 'ratingCount', 'averageRating', 'contributionCount', 'thumbnailUrl', 'categoryVotes', 'menuPhotoCount', 'reportCount', 'updatedAt'])
         || (request.auth.uid == resource.data.addedBy
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['categories', 'phone', 'website', 'cuisineTypes', 'priceLevel', 'addedByName', 'updatedAt']))
         ));
      allow delete: if isAdmin()
        || (request.auth != null
        && request.auth.uid == resource.data.addedBy
        && ((!('contributionCount' in resource.data)) || resource.data.contributionCount == 0));

      // Piatti
      match /dishes/{dishId} {
        allow read: if isAdmin() || resource == null || resource.data.status == 'active';
        allow create: if request.auth != null
          && request.resource.data.addedBy == request.auth.uid;
        allow update, delete: if isAdmin();
      }

      // Recensioni
      match /reviews/{reviewId} {
        allow read: if isAdmin() || resource == null || resource.data.status == 'active';
        allow update, delete: if isAdmin();
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && (!('imageUrl' in request.resource.data.keys()) || request.resource.data.imageUrl is string);
      }

      // Foto menu (community-managed)
      match /menuPhotos/{photoId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.uploadedBy == request.auth.uid;
        allow delete: if isAdmin()
          || (request.auth != null && resource.data.uploadedBy == request.auth.uid);
      }

      // Contributi (valutazioni + piatti)
      match /contributions/{contributionId} {
        allow read: if isAdmin() || resource == null || resource.data.status == 'active';
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin()
          || (request.auth != null && resource.data.userId == request.auth.uid);
      }

      // Segnalazioni: lettura per tutti gli autenticati, scrittura solo dall'autore
      // Admin: lettura e aggiornamento status
      match /reports/{reportId} {
        allow read: if request.auth != null;
        allow update, delete: if isAdmin();
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.reason is string
          && request.resource.data.reason in ['closed', 'incorrect_info', 'hygiene', 'inappropriate', 'other']
          && request.resource.data.description is string
          && request.resource.data.description.size() > 0
          && request.resource.data.description.size() <= 500
          && request.resource.data.status == 'active';
        allow update: if request.auth != null
          && resource.data.userId == request.auth.uid
          && request.resource.data.reason in ['closed', 'incorrect_info', 'hygiene', 'inappropriate', 'other']
          && request.resource.data.description is string
          && request.resource.data.description.size() > 0
          && request.resource.data.description.size() <= 500;
      }

      // Like sui piatti: lettura pubblica, scrittura solo dal proprietario del like
      match /dishLikes/{likeId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isAdmin()
          || (request.auth != null && resource.data.userId == request.auth.uid);
      }
    }
  }
}
